{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Toodoo",
  "version": "1.9.7",
  "identifier": "com.toodoo.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Toodoo",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["toodoo"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/EphraimTJ/toodoo/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGQkI4QjZFNzJGREY3N0QKUldSOTkvMXlib3U3YjJVZHBPT2VxdlVFVEJLTXpxVXJUMDIyTCt3elhreHpsZUd0aTA0dGJLYTYK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
